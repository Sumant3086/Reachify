PORT=3001
NODE_ENV=development
TZ=Asia/Kolkata

# Database (Choose one option)
# Option 1: Full connection string (Supabase, Neon, etc.)
DATABASE_URL=postgresql://user:password@host:5432/reachify

# Option 2: Individual parameters
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=password
# DB_NAME=reachify

# Redis (Upstash or local)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Email Service (Resend recommended - 3000 emails/month free)
# Get free API key at https://resend.com
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_your_api_key_here

# Alternative: Ethereal (testing only, emails not delivered)
# SMTP_HOST=smtp.ethereal.email
# SMTP_PORT=587
# SMTP_USER=your-ethereal-user
# SMTP_PASS=your-ethereal-pass

# Google OAuth
# Get credentials at https://console.cloud.google.com
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# Session (auto-generated if not provided)
SESSION_SECRET=

# Frontend
FRONTEND_URL=https://reachify-io.onrender.com

# Worker Configuration
WORKER_CONCURRENCY=5
EMAIL_DELAY_MS=2000
MAX_EMAILS_PER_HOUR=200

# Logging
LOG_LEVEL=info

# Production (Render)
GOOGLE_CALLBACK_URL=https://reachify-backend-jep1.onrender.com/auth/google/callback
FRONTEND_URL=https://reachify-io.onrender.com
